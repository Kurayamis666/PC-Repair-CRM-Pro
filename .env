# .env
# ============================================
# PC Repair CRM Pro - Environment Configuration
# ============================================
# ⚠️  ЭТОТ ФАЙЛ НЕ ДОЛЖЕН ПОПАДАТЬ В РЕПОЗИТОРИЙ!
# ⚠️  Добавьте .env в .gitignore
# ============================================

# === 🗄️ DATABASE ===
# Путь к базе данных (относительный или абсолютный)
# Для .exe: будет создан рядом с исполняемым файлом, если путь относительный
DB_PATH=data/repair_shop.db

# Настройки SQLite (опционально)
DB_TIMEOUT=30
DB_WAL_MODE=true
DB_FOREIGN_KEYS=true

# === 📧 SMTP EMAIL SETTINGS ===
# Gmail пример: smtp.gmail.com:587
# Яндекс: smtp.yandex.ru:465
# Mail.ru: smtp.mail.ru:465
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=noreply@yourdomain.com
SMTP_USER=your_email@gmail.com
# ⚠️ Используйте App Password, не основной пароль!
# Получите в: https://myaccount.google.com/apppasswords
SMTP_PASS=your_app_password_here
SMTP_TLS=true
SMTP_TIMEOUT=30

# === 📱 SMS API SETTINGS ===
# Поддерживаемые провайдеры: twilio, smsru, smsc, custom
SMS_PROVIDER=twilio
SMS_API_KEY=your_api_key_here
SMS_API_SECRET=your_api_secret_here
SMS_SENDER=PCRepair
SMS_TIMEOUT=30

# Пример для SMS.ru:
# SMS_PROVIDER=smsru
# SMS_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# === 🌐 APPLICATION ===
DEFAULT_LANGUAGE=ru
SUPPORTED_LANGUAGES=ru,en
THEME=dark
# Темы: dark, light, system

# === 🔐 SECURITY ===
# Соль для хеширования паролей (минимум 32 символа)
# Сгенерируйте: python -c "import secrets; print(secrets.token_hex(32))"
PASSWORD_SALT=change_this_to_random_32_char_string_abc123!

# Время жизни сессии в минутах (0 = бессрочно)
SESSION_TIMEOUT=480

# Требовать повторный вход для чувствительных операций
REAUTH_FOR_SENSITIVE=true

# === 📊 LOGGING ===
# Уровни: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(name)s | %(message)s

# === 💾 BACKUP ===
# Авто-бэкап БД при запуске (true/false)
AUTO_BACKUP=true
BACKUP_DIR=data/backups
BACKUP_KEEP_DAYS=30
BACKUP_COMPRESS=true

# === 🏷️ BARCODES & LABELS ===
# Папка для сгенерированных этикеток
LABELS_DIR=reports/barcodes
# Формат: png, jpg, pdf
LABEL_FORMAT=png
# DPI для печати
LABEL_DPI=300

# === 📈 REPORTS ===
# Валюта по умолчанию для отчётов
DEFAULT_CURRENCY=RUB
# Ставка налога в % (0 = без налога)
TAX_RATE=0
# Показать налоги в отчётах
SHOW_TAX_IN_REPORTS=false

# === ⚡ PERFORMANCE ===
# Кэширование запросов к БД (в секундах)
DB_CACHE_TTL=60
# Максимальное количество записей в таблице без пагинации
MAX_ROWS_PER_PAGE=100
# Автосохранение при редактировании (сек)
AUTO_SAVE_INTERVAL=30

# === 🧪 DEVELOPMENT ===
# Режим отладки (не включать в продакшен!)
DEBUG=false
# Показать отладочную информацию в UI
SHOW_DEBUG_INFO=false
# Загружать тестовые данные при пустой БД
LOAD_DEMO_ON_EMPTY=true

# === 🔄 UPDATES ===
# Проверка обновлений при запуске
CHECK_UPDATES=true
# URL для проверки новой версии
UPDATE_CHECK_URL=https://api.github.com/repos/youruser/pc-repair-crm/releases/latest