# .env.example
# ============================================
# PC Repair CRM Pro - Example Environment
# Скопируйте в .env и заполните значениями
# ============================================

# === 🗄️ DATABASE ===
DB_PATH=data/repair_shop.db

# === 📧 SMTP ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=noreply@yourdomain.com
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_TLS=true

# === 📱 SMS ===
SMS_PROVIDER=twilio
SMS_API_KEY=your_api_key_here
SMS_SENDER=PCRepair

# === 🔐 SECURITY ===
PASSWORD_SALT=change_this_to_random_string

# === 🌐 APP ===
DEFAULT_LANGUAGE=ru
THEME=dark

# === 📊 LOGGING ===
LOG_LEVEL=INFO